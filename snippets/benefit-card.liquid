{% comment %}
  Usage: {% render 'benefit-card', title: block.settings.title, description: block.settings.description, image: block.settings.image %}
{% endcomment %}
<div class="fb-benefit-card">
  {%- if image != blank -%}
    <div class="fb-benefit-card__image">
      {{ image | image_url: width: 600 | image_tag: loading: 'lazy', alt: title }}
    </div>
  {%- else -%}
    <div class="fb-benefit-card__image fb-benefit-card__image--placeholder">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#7cb342" stroke-width="1.5" opacity="0.4"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
    </div>
  {%- endif -%}
  <div class="fb-benefit-card__body">
    {%- if title != blank -%}
      <h3 class="fb-benefit-card__title">{{ title }}</h3>
    {%- endif -%}
    {%- if description != blank -%}
      <p class="fb-benefit-card__desc">{{ description }}</p>
    {%- endif -%}
  </div>
</div>
