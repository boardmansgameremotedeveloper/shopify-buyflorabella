<section class="fb-featured-product">
  <div class="fb-container" style="position:relative;z-index:1;">
    <div class="fb-featured-product__grid">

      {%- comment -%} Product card (left on desktop) {%- endcomment -%}
      <div class="fb-featured-product__card">
        <div class="fb-featured-product__badge">{{ section.settings.badge_text | default: 'Best Seller' }}</div>

        {%- if section.settings.product != blank -%}
          {%- assign fp = section.settings.product -%}
          {%- if fp.featured_image != blank -%}
            {{ fp.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: fp.title, class: 'fb-featured-product__image fb-parallax-float' }}
          {%- endif -%}

          <div style="display:flex;gap:0.25rem;margin-bottom:1rem;">
            {%- for i in (1..5) -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#7cb342" stroke="#7cb342" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endfor -%}
            <span style="color:rgba(255,255,255,0.5);font-size:0.875rem;margin-left:0.5rem;">({{ section.settings.review_count | default: 487 }} reviews)</span>
          </div>

          <h3 style="color:#fff;font-size:1.5rem;font-weight:800;margin:0 0 0.5rem;font-family:var(--font-heading-family);">{{ fp.title }}</h3>

          <p class="fb-featured-product__price">
            {{ fp.price | money }}
          </p>

          {%- if fp.variants.size > 1 -%}
            <div style="margin-bottom:1rem;">
              <label style="color:rgba(255,255,255,0.6);font-size:0.875rem;font-weight:500;display:block;margin-bottom:0.5rem;">Select size</label>
              <select class="fb-featured-product__select" id="fp-variant-{{ section.id }}">
                {%- for variant in fp.variants -%}
                  <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.title }} — {{ variant.price | money }}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endif -%}

          <div style="display:flex;gap:0.75rem;flex-direction:column;">
            {%- form 'product', fp, id: 'fp-form-{{ section.id }}' -%}
              {%- if fp.variants.size > 1 -%}
                <input type="hidden" name="id" id="fp-variant-input-{{ section.id }}" value="{{ fp.selected_or_first_available_variant.id }}">
              {%- else -%}
                <input type="hidden" name="id" value="{{ fp.variants.first.id }}">
              {%- endif -%}
              <input type="hidden" name="quantity" value="1">
              <button
                type="submit"
                class="fb-btn-primary"
                style="width:100%;justify-content:center;"
                {% unless fp.available %}disabled{% endunless %}
              >
                {% if fp.available %}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                  Add to Cart
                {% else %}
                  Sold Out
                {% endif %}
              </button>
            {%- endform -%}
            <a href="{{ fp.url }}" class="fb-btn-secondary" style="text-align:center;">View full details</a>
          </div>
        {%- else -%}
          <div style="color:rgba(255,255,255,0.4);text-align:center;padding:3rem;">
            <p>Select a product in section settings</p>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: description & benefits {%- endcomment -%}
      <div style="color:#fff;">
        {%- if section.settings.eyebrow != blank -%}
          <div class="fb-badge" style="margin-bottom:1rem;">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        <h2 class="fb-section-title fb-heading" style="color:#fff;margin-bottom:1rem;">{{ section.settings.heading }}</h2>
        <p style="color:rgba(255,255,255,0.7);font-size:1.0625rem;line-height:1.75;margin-bottom:2rem;">{{ section.settings.description }}</p>

        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div style="display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.25rem;padding:1rem;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:0.875rem;" {{ block.shopify_attributes }}>
              <div style="width:2.5rem;height:2.5rem;min-width:2.5rem;background:rgba(124,179,66,0.15);border-radius:0.625rem;display:flex;align-items:center;justify-content:center;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7cb342" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <p style="color:#fff;font-weight:700;margin:0 0 0.25rem;font-size:0.9375rem;">{{ block.settings.title }}</p>
                <p style="color:rgba(255,255,255,0.55);font-size:0.875rem;margin:0;line-height:1.6;">{{ block.settings.description }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{%- if section.settings.product.variants.size > 1 -%}
<script>
  (function() {
    var sel = document.getElementById('fp-variant-{{ section.id }}');
    var inp = document.getElementById('fp-variant-input-{{ section.id }}');
    if (sel && inp) {
      sel.addEventListener('change', function() { inp.value = this.value; });
    }
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Featured Product Hero",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Featured product"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Product badge",
      "default": "Best Seller"
    },
    {
      "type": "number",
      "id": "review_count",
      "label": "Review count (display only)",
      "default": 487
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "FEATURED PRODUCT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Flora Bella Bio Trace Mix"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Product description",
      "default": "Our signature blend of over 70 trace minerals, humic acid, fulvic acid, and beneficial biology. One addition to your watering routine transforms how your soil performs."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature bullet",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Feature title",
          "default": "70+ trace minerals"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Feature description",
          "default": "A full spectrum of naturally occurring trace minerals in every application."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Product Hero",
      "blocks": [
        { "type": "feature", "settings": { "title": "70+ Trace Minerals", "description": "A full spectrum of naturally occurring trace minerals in every application." } },
        { "type": "feature", "settings": { "title": "Humic & Fulvic Acids", "description": "Supports mineral transport and soil structure at the microscopic level." } },
        { "type": "feature", "settings": { "title": "Beneficial Biology", "description": "Natural microbes that awaken dormant soil potential and support root health." } }
      ]
    }
  ]
}
{% endschema %}
