<section style="background:{{ section.settings.background_color }};padding:5rem 0;">
  <div class="fb-container">
    {%- if section.settings.heading != blank -%}
      <div style="text-align:center;margin-bottom:3rem;">
        <h2 class="fb-section-title fb-heading" style="color:{{ section.settings.heading_color }};margin-bottom:0.75rem;">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p style="color:{{ section.settings.subheading_color }};font-size:1.125rem;">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.video_type == 'shopify' and section.settings.video != blank -%}
      <div style="border-radius:1.25rem;overflow:hidden;max-width:56rem;margin:0 auto;box-shadow:0 30px 80px rgba(0,0,0,0.4);">
        {{- section.settings.video | video_tag: autoplay: false, loop: section.settings.loop, controls: true, muted: section.settings.muted, style: 'width:100%;display:block;' -}}
      </div>
    {%- elsif section.settings.video_url != blank -%}
      {%- assign clean_url = section.settings.video_url -%}
      {%- if clean_url contains 'youtube.com/watch' -%}
        {%- assign video_id = clean_url | split: 'v=' | last | split: '&' | first -%}
        <div style="border-radius:1.25rem;overflow:hidden;max-width:56rem;margin:0 auto;box-shadow:0 30px 80px rgba(0,0,0,0.4);aspect-ratio:16/9;">
          <iframe
            src="https://www.youtube.com/embed/{{ video_id }}"
            title="{{ section.settings.heading }}"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="width:100%;height:100%;display:block;"
          ></iframe>
        </div>
      {%- elsif clean_url contains 'youtu.be/' -%}
        {%- assign video_id = clean_url | split: 'youtu.be/' | last | split: '?' | first -%}
        <div style="border-radius:1.25rem;overflow:hidden;max-width:56rem;margin:0 auto;box-shadow:0 30px 80px rgba(0,0,0,0.4);aspect-ratio:16/9;">
          <iframe
            src="https://www.youtube.com/embed/{{ video_id }}"
            title="{{ section.settings.heading }}"
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            style="width:100%;height:100%;display:block;"
          ></iframe>
        </div>
      {%- elsif clean_url contains 'vimeo.com/' -%}
        {%- assign video_id = clean_url | split: 'vimeo.com/' | last | split: '?' | first -%}
        <div style="border-radius:1.25rem;overflow:hidden;max-width:56rem;margin:0 auto;box-shadow:0 30px 80px rgba(0,0,0,0.4);aspect-ratio:16/9;">
          <iframe
            src="https://player.vimeo.com/video/{{ video_id }}"
            title="{{ section.settings.heading }}"
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            style="width:100%;height:100%;display:block;"
          ></iframe>
        </div>
      {%- else -%}
        <div style="border-radius:1.25rem;overflow:hidden;max-width:56rem;margin:0 auto;box-shadow:0 30px 80px rgba(0,0,0,0.4);">
          <video src="{{ clean_url }}" controls {% if section.settings.loop %}loop{% endif %} {% if section.settings.muted %}muted{% endif %} style="width:100%;display:block;"></video>
        </div>
      {%- endif -%}
    {%- else -%}
      <div style="max-width:56rem;margin:0 auto;border-radius:1.25rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;">
        <p style="color:rgba(255,255,255,0.4);">Add a video URL or Shopify video in section settings</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Video Reels",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See Flora Bella In Action"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-heading",
      "default": "Real gardens. Real results."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Sub-heading color",
      "default": "#9ca3af"
    },
    {
      "type": "select",
      "id": "video_type",
      "label": "Video type",
      "options": [
        { "value": "url", "label": "URL (YouTube / Vimeo / direct)" },
        { "value": "shopify", "label": "Shopify-hosted video" }
      ],
      "default": "url"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted video"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "Paste a YouTube, Vimeo, or direct .mp4 URL"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute video",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Video Reels"
    }
  ]
}
{% endschema %}
