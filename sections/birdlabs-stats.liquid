{% style %}
  #birdlabs-stats-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #birdlabs-stats-{{ section.id }} .st-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  #birdlabs-stats-{{ section.id }} .st-header {
    text-align: {{ section.settings.header_align }};
    margin-bottom: 3rem;
  }

  #birdlabs-stats-{{ section.id }} .st-heading {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  #birdlabs-stats-{{ section.id }} .st-description {
    font-size: 1.125rem;
    color: {{ section.settings.description_color }};
    line-height: 1.7;
    margin: 0;
    max-width: 60ch;
    {% if section.settings.header_align == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
    {% if section.settings.header_align == 'right' %}margin-left: auto;{% endif %}
  }

  /* ── Stats grid ── */
  #birdlabs-stats-{{ section.id }} .st-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: {{ section.settings.card_gap }}px;
  }

  @media (min-width: 480px) {
    #birdlabs-stats-{{ section.id }} .st-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    #birdlabs-stats-{{ section.id }} .st-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  /* ── Stat card ── */
  #birdlabs-stats-{{ section.id }} .st-card {
    border: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    background: {{ section.settings.card_bg }};
    padding: {{ section.settings.card_padding }}px;
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.card_align }};
    text-align: {% if section.settings.card_align == 'flex-start' %}left{% elsif section.settings.card_align == 'flex-end' %}right{% else %}center{% endif %};
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  #birdlabs-stats-{{ section.id }} .st-card:hover {
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }
{% endstyle %}

<section id="birdlabs-stats-{{ section.id }}">
  <div class="st-container">

    {% if section.settings.heading != blank or section.settings.description != blank %}
      <div class="st-header">
        {% if section.settings.heading != blank %}
          <h2 class="st-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="st-description">{{ section.settings.description }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="st-grid">
        {% for block in section.blocks %}
          {% if block.type == 'stat' %}
            <div class="st-card" {{ block.shopify_attributes }}>
              {% if block.settings.value != blank %}
                <p style="
                  font-size: {{ block.settings.value_size }}rem;
                  font-weight: 800;
                  color: {{ block.settings.value_color }};
                  margin: 0 0 0.35rem;
                  line-height: 1;
                ">{{ block.settings.value }}</p>
              {% endif %}
              {% if block.settings.label != blank %}
                <p style="
                  font-size: {{ block.settings.label_size }}rem;
                  color: {{ block.settings.label_color }};
                  margin: 0;
                  line-height: 1.4;
                ">{{ block.settings.label }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <p style="text-align:center;color:#9ca3af;padding:2rem 0;">Add stat blocks in the theme editor.</p>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "BirdLabs — Stats",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "header_align",
      "label": "Header alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#4b5563"
    },
    {
      "type": "header",
      "content": "Grid"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Gap between cards",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e5e7eb"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Border width",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "card_align",
      "label": "Card content alignment",
      "options": [
        { "value": "flex-start", "label": "Left"   },
        { "value": "center",     "label": "Center" },
        { "value": "flex-end",   "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#f9fafb"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Stat value",
          "info": "e.g. \"50+\" or \"10,000\"",
          "default": "50+"
        },
        {
          "type": "range",
          "id": "value_size",
          "label": "Value font size",
          "min": 2,
          "max": 6,
          "step": 1,
          "unit": "rem",
          "default": 3
        },
        {
          "type": "color",
          "id": "value_color",
          "label": "Value color",
          "default": "#111111"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "e.g. \"Years in Use\"",
          "default": "Years in Use"
        },
        {
          "type": "range",
          "id": "label_size",
          "label": "Label font size",
          "min": 1,
          "max": 2,
          "step": 1,
          "unit": "rem",
          "default": 1
        },
        {
          "type": "color",
          "id": "label_color",
          "label": "Label color",
          "default": "#6b7280"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BirdLabs — Stats",
      "blocks": [
        {
          "type": "stat",
          "settings": { "value": "50+", "label": "Years in Use" }
        },
        {
          "type": "stat",
          "settings": { "value": "70+", "label": "Trace Minerals" }
        },
        {
          "type": "stat",
          "settings": { "value": "10k+", "label": "Happy Growers" }
        }
      ]
    }
  ]
}
{% endschema %}
