{% style %}
  #birdlabs-ig-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #birdlabs-ig-{{ section.id }} .ig-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  #birdlabs-ig-{{ section.id }} .ig-heading {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 2rem;
    line-height: 1.2;
  }

  /* Desktop: single row of 6 fixed-size square thumbnails */
  #birdlabs-ig-{{ section.id }} .ig-grid {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    gap: {{ section.settings.gap }}px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  #birdlabs-ig-{{ section.id }} .ig-grid::-webkit-scrollbar {
    display: none;
  }

  #birdlabs-ig-{{ section.id }} .ig-item {
    display: block;
    flex-shrink: 0;
    width: {{ section.settings.thumbnail_size }}px;
    height: {{ section.settings.thumbnail_size }}px;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
    position: relative;
    text-decoration: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  #birdlabs-ig-{{ section.id }} .ig-item:hover {
    transform: translateY(-8px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.18);
  }

  #birdlabs-ig-{{ section.id }} .ig-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #birdlabs-ig-{{ section.id }} .ig-item--static {
    cursor: default;
  }

  #birdlabs-ig-{{ section.id }} .ig-placeholder {
    width: 100%;
    height: 100%;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9ca3af;
    font-size: 0.8rem;
  }

  #birdlabs-ig-{{ section.id }} .ig-empty {
    text-align: center;
    color: #9ca3af;
    padding: 3rem 0;
    font-size: 0.9rem;
  }

  /* Mobile: 2-column responsive grid */
  @media (max-width: 767px) {
    #birdlabs-ig-{{ section.id }} .ig-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      flex-wrap: unset;
      justify-content: unset;
      overflow-x: unset;
    }

    #birdlabs-ig-{{ section.id }} .ig-item {
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      flex-shrink: unset;
    }
  }
{% endstyle %}

<section id="birdlabs-ig-{{ section.id }}">
  <div class="ig-container">

    {% if section.settings.heading != blank %}
      <h2 class="ig-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="ig-grid">
        {% for block in section.blocks %}

          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="ig-item" {{ block.shopify_attributes }}>
          {% else %}
            <div class="ig-item ig-item--static" {{ block.shopify_attributes }}>
          {% endif %}

          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | img_url: '600x600', crop: 'center' }}"
              srcset="
                {{ block.settings.image | img_url: '300x300', crop: 'center' }} 300w,
                {{ block.settings.image | img_url: '600x600', crop: 'center' }} 600w
              "
              sizes="(max-width: 767px) 50vw, {{ section.settings.thumbnail_size }}px"
              alt="featured highlight"
              loading="lazy"
              width="{{ section.settings.thumbnail_size }}"
              height="{{ section.settings.thumbnail_size }}"
            >
          {% else %}
            <div class="ig-placeholder">Add image</div>
          {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% else %}
            </div>
          {% endif %}

        {% endfor %}
      </div>
    {% else %}
      <p class="ig-empty">Add image blocks in the theme editor to display the gallery.</p>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "BirdLabs — Image Gallery",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Thumbnails"
    },
    {
      "type": "range",
      "id": "thumbnail_size",
      "label": "Thumbnail size",
      "info": "Width and height of each square thumbnail (desktop). On mobile, thumbnails fill 50% of screen width.",
      "min": 60,
      "max": 320,
      "step": 10,
      "unit": "px",
      "default": 160
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between thumbnails",
      "min": 4,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BirdLabs — Image Gallery",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
