<section class="fb-how fb-gradient-offwhite">
  <div class="fb-container" style="position:relative;z-index:1;">
    <div style="text-align:center;margin-bottom:5rem;">
      <h2 class="fb-section-title fb-heading" style="color:#111;margin-bottom:1rem;">{{ section.settings.heading }}</h2>
      <p class="fb-section-subtitle" style="color:#4b5563;">{{ section.settings.subheading }}</p>
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'step' -%}
        {%- assign is_even = forloop.index | modulo: 2 -%}
        <div class="fb-how__step{% if is_even == 0 %} fb-how__step--reverse{% endif %}" {{ block.shopify_attributes }}>
          <div class="fb-how__step-content">
            <div class="fb-step-number">{{ block.settings.step_number | default: forloop.index | prepend: '0' | slice: -2, 2 }}</div>
            <h3 style="font-size:1.75rem;font-weight:800;color:#111;margin:0.5rem 0 0.75rem;font-family:var(--font-heading-family);">{{ block.settings.title }}</h3>
            <p style="color:#4b5563;font-size:1rem;margin-bottom:1rem;">{{ block.settings.description }}</p>
            {%- if block.settings.highlights != blank -%}
              <ul class="fb-how__step-highlights">
                {%- assign items = block.settings.highlights | split: '|' -%}
                {%- for item in items -%}
                  <li>{{ item | strip }}</li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          <div class="fb-how__step-image">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {%- elsif block.settings.image_url != blank -%}
              <img src="{{ block.settings.image_url }}" alt="{{ block.settings.title }}" loading="lazy" style="width:100%;height:20rem;object-fit:cover;">
            {%- else -%}
              <div style="width:100%;height:20rem;background:rgba(124,179,66,0.1);border-radius:1rem;display:flex;align-items:center;justify-content:center;">
                <span style="color:rgba(124,179,66,0.4);font-size:3rem;">🌿</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "How Flora Bella Works With Your Soil"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-heading",
      "default": "A precise blend of over 70 trace minerals working in harmony with your soil"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Beneficial Microbes"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Naturally occurring beneficial bacteria that power your soil ecosystem."
        },
        {
          "type": "textarea",
          "id": "highlights",
          "label": "Bullet highlights (separate with |)",
          "default": "Convert nutrients into forms plants can absorb|Support root development through natural growth signaling|Compete with harmful organisms in the root zone|Improve tolerance to environmental stress"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step image"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "Image URL (if not using image picker)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_number": "01",
            "title": "Beneficial Microbes",
            "description": "Naturally occurring beneficial bacteria that transform your soil ecosystem.",
            "highlights": "Convert nutrients into forms plants can absorb|Support root development through natural growth signaling|Compete with harmful organisms in the root zone|Improve tolerance to environmental stress (drought, heat, poor soil)"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "02",
            "title": "Humic Acid — Soil Structure & Retention",
            "description": "Humic acids are large organic compounds that improve how your soil holds and delivers nutrition.",
            "highlights": "Improve soil structure, aggregation, and aeration|Increase water-holding capacity|Bind and retain nutrients in the root zone|Support beneficial microbial activity"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_number": "03",
            "title": "Fulvic Acid — Mineral Transport",
            "description": "Fulvic acids are smaller, highly bioavailable organic compounds that carry minerals where they're needed.",
            "highlights": "Bind trace minerals into plant-usable forms|Facilitate movement of minerals through plant cell walls|Improve nutrient uptake efficiency"
          }
        }
      ]
    }
  ]
}
{% endschema %}
