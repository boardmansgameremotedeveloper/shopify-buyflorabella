<section class="fb-hero fb-gradient-offwhite" id="fb-hero-{{ section.id }}">

  <div class="fb-hero__bg-blob" style="width:16rem;height:16rem;background:#7cb342;top:5rem;left:2.5rem;"></div>
  <div class="fb-hero__bg-blob" style="width:24rem;height:24rem;background:#8b6f47;bottom:5rem;right:2.5rem;"></div>

  <div class="fb-container fb-hero__container">

    <div class="fb-hero__grid">

      <!-- LEFT: CONTENT -->
      <div class="fb-hero__content">

        {%- if section.settings.show_buy_badge -%}
          <div class="fb-hero__eyebrow">
            <a href="{{ section.settings.button_primary_url | default: '/collections/all' }}" class="fb-btn-primary" style="font-size:0.875rem;padding:0.625rem 1.5rem;">
              {{ section.settings.buy_badge_label | default: 'BUY NOW' }}
            </a>
          </div>
        {%- endif -%}

        <h1 class="fb-hero__headline fb-heading">
          {{ section.settings.headline | newline_to_br }}
        </h1>

        <p class="fb-hero__subheadline">
          {{ section.settings.subheadline }}
        </p>

        <p class="fb-hero__body">
          {{ section.settings.body_text }}
        </p>

        {%- if section.settings.trust_box_text != blank -%}
          <div class="fb-hero__trust-box">
            <p>
              <strong style="color:#111;">
                {{ section.settings.trust_box_heading }}
              </strong>
              {{ section.settings.trust_box_text }}
            </p>
          </div>
        {%- endif -%}

        <div class="fb-hero__cta-row">
          {%- if section.settings.button_primary_label != blank -%}
            <a href="{{ section.settings.button_primary_url | default: '/collections/all' }}" class="fb-btn-primary">
              {{ section.settings.button_primary_label }}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          {%- endif -%}

          {%- if section.settings.button_secondary_label != blank -%}
            <a href="{{ section.settings.button_secondary_url | default: '/community' }}" class="fb-btn-secondary">
              {{ section.settings.button_secondary_label }}
            </a>
          {%- endif -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <ul class="fb-checklist">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust_item' -%}
                <li {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

      </div>

      <!-- RIGHT: IMAGE (single source of truth) -->
      {%- if section.settings.hero_image != blank -%}
        <div class="fb-hero__image-wrap fb-hero__image">

          <div class="fb-hero__image-glow"></div>

          {{ section.settings.hero_image
            | image_url: width: 1000
            | image_tag:
              loading: 'eager',
              alt: section.settings.headline,
              class: 'fb-hero__img'
          }}

        </div>
      {%- endif -%}

    </div>

  </div>

</section>

<style>
/* =========================
   SECTION SPACING CONTROL
   ========================= */
#fb-hero-{{ section.id }} {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

/* =========================
   GRID LAYOUT (FIXED)
   ========================= */
.fb-hero__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
}

@media (min-width: 1024px) {
  .fb-hero__grid {
    grid-template-columns: 1.1fr 0.9fr;
  }
}

/* =========================
   IMAGE STYLING
   ========================= */
.fb-hero__image {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

.fb-hero__img {
  width: 100%;
  border-radius: 1.25rem;
  box-shadow: 0 30px 80px rgba(0,0,0,0.15);
  position: relative;
  z-index: 2;
}

/* glow background */
.fb-hero__image-glow {
  position: absolute;
  inset: -1rem;
  background: linear-gradient(
    135deg,
    rgba(124,179,66,0.25),
    rgba(139,111,71,0.25)
  );
  filter: blur(2rem);
  border-radius: 2rem;
  z-index: 1;
}

/* =========================
   OPTIONAL ANIMATION
   ========================= */
{%- if section.settings.enable_image_animation -%}
@keyframes fb-hero-breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.fb-hero__img {
  animation: fb-hero-breathe 4s ease-in-out infinite;
  transform-origin: center;
}
{%- endif -%}

/* =========================
   SAFETY SPACING TUNING
   ========================= */
.fb-hero__content {
  margin-top: 0;
}
</style>

{% schema %}
{
  "name": "BirdLabs — Hero (Clean)",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Wake Up\nYour Soil"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Sub-headline",
      "default": "Bio trace minerals that make every drop of fertilizer work harder."
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "Flora Bella delivers commercial-grade trace minerals..."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "checkbox",
      "id": "enable_image_animation",
      "label": "Enable image animation",
      "default": false
    },
    {
      "type": "text",
      "id": "button_primary_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "button_secondary_label",
      "label": "Secondary button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "checkbox",
      "id": "show_buy_badge",
      "label": "Show BUY badge",
      "default": true
    },
    {
      "type": "text",
      "id": "buy_badge_label",
      "label": "Badge label",
      "default": "BUY NOW"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 64,
      "label": "Top padding"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 64,
      "label": "Bottom padding"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust bullet",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Over seventy trace minerals"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BirdLabs — Hero (Clean)"
    }
  ]
}
{% endschema %}