{% liquid
  assign h_align = section.settings.header_h_align | default: 'center'
  case h_align
    when 'left'
      assign text_align  = 'left'
      assign flex_items  = 'flex-start'
    when 'right'
      assign text_align  = 'right'
      assign flex_items  = 'flex-end'
    else
      assign text_align  = 'center'
      assign flex_items  = 'center'
  endcase

  assign v_align = section.settings.header_v_align | default: 'top'
  case v_align
    when 'center'
      assign flex_justify = 'center'
    when 'bottom'
      assign flex_justify = 'flex-end'
    else
      assign flex_justify = 'flex-start'
  endcase
%}

{% style %}
  #birdlabs-cg-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #birdlabs-cg-{{ section.id }} .cg-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header alignment ── */
  #birdlabs-cg-{{ section.id }} .cg-header-wrap {
    margin-bottom: 3rem;
    {% if section.settings.header_height > 0 %}
    min-height: {{ section.settings.header_height }}px;
    display: flex;
    flex-direction: column;
    justify-content: {{ flex_justify }};
    align-items: {{ flex_items }};
    {% endif %}
  }

  #birdlabs-cg-{{ section.id }} .cg-header {
    text-align: {{ text_align }};
    {% if section.settings.header_height == 0 %}
    width: 100%;
    {% endif %}
  }

  #birdlabs-cg-{{ section.id }} .cg-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.badge_color }};
    background: {{ section.settings.badge_bg }};
    padding: 0.3rem 0.85rem;
    border-radius: 9999px;
    margin-bottom: 1rem;
  }

  #birdlabs-cg-{{ section.id }} .cg-heading {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  #birdlabs-cg-{{ section.id }} .cg-description {
    font-size: 1.125rem;
    color: {{ section.settings.description_color }};
    line-height: 1.7;
    margin: 0;
    max-width: 60ch;
    {% if text_align == 'center' %}margin-left: auto; margin-right: auto;{% endif %}
    {% if text_align == 'right' %}margin-left: auto;{% endif %}
  }

  /* ── Gallery grid ── */
  #birdlabs-cg-{{ section.id }} .cg-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  @media (min-width: 640px) {
    #birdlabs-cg-{{ section.id }} .cg-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    #birdlabs-cg-{{ section.id }} .cg-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  #birdlabs-cg-{{ section.id }} .cg-item {
    position: relative;
    overflow: hidden;
    border-radius: {{ section.settings.image_radius }}px;
    aspect-ratio: 1 / 1;
    cursor: pointer;
    background: #1f2937;
  }

  #birdlabs-cg-{{ section.id }} .cg-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  #birdlabs-cg-{{ section.id }} .cg-item:hover img {
    transform: scale(1.06);
  }

  #birdlabs-cg-{{ section.id }} .cg-item-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.75), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  #birdlabs-cg-{{ section.id }} .cg-item:hover .cg-item-overlay {
    opacity: 1;
  }

  #birdlabs-cg-{{ section.id }} .cg-item-caption {
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
    margin: 0 0 0.2rem;
  }

  #birdlabs-cg-{{ section.id }} .cg-item-author {
    color: rgba(255,255,255,0.65);
    font-size: 0.75rem;
    margin: 0;
  }

  /* ── CTA ── */
  #birdlabs-cg-{{ section.id }} .cg-cta-wrap {
    text-align: center;
    margin-top: 3rem;
  }

  #birdlabs-cg-{{ section.id }} .cg-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: {{ section.settings.cta_bg }};
    color: {{ section.settings.cta_color }};
    padding: 0.875rem 2rem;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: filter 0.2s;
  }

  #birdlabs-cg-{{ section.id }} .cg-cta:hover {
    filter: brightness(0.9);
  }

  /* ── Empty placeholder ── */
  #birdlabs-cg-{{ section.id }} .cg-placeholder {
    width: 100%;
    height: 100%;
    background: rgba(124,179,66,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
  }
{% endstyle %}

<section id="birdlabs-cg-{{ section.id }}">
  <div class="cg-container">

    {%- comment -%} Header block with 9-quadrant alignment {%- endcomment -%}
    <div class="cg-header-wrap">
      <div class="cg-header">
        {% if section.settings.badge_text != blank %}
          <div class="cg-badge">{{ section.settings.badge_text }}</div>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h1 class="cg-heading">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.description != blank %}
          <p class="cg-description">{{ section.settings.description }}</p>
        {% endif %}
      </div>
    </div>

    {%- comment -%} Gallery grid {%- endcomment -%}
    {% if section.blocks.size > 0 %}
      <div class="cg-grid">
        {% for block in section.blocks %}
          {% if block.type == 'gallery_image' %}
            <div
              class="cg-item"
              {{ block.shopify_attributes }}
              data-cg-trigger
              data-caption="{{ block.settings.caption | escape }}"
              data-author="{{ block.settings.author | escape }}"
              {% if block.settings.image != blank %}
                data-src="{{ block.settings.image | image_url: width: 1200 }}"
              {% endif %}
            >
              {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.caption }}
              {% else %}
                <div class="cg-placeholder">🌿</div>
              {% endif %}
              <div class="cg-item-overlay">
                <p class="cg-item-caption">{{ block.settings.caption }}</p>
                <p class="cg-item-author">{{ block.settings.author }}</p>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {%- comment -%} CTA button {%- endcomment -%}
    {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
      <div class="cg-cta-wrap">
        <a href="{{ section.settings.cta_url }}" class="cg-cta" target="_blank" rel="noopener noreferrer">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {% endif %}

  </div>
</section>

{%- comment -%} Lightbox modal {%- endcomment -%}
<div
  id="cg-modal-{{ section.id }}"
  style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.9);align-items:center;justify-content:center;"
  aria-hidden="true"
  role="dialog"
>
  <button
    id="cg-modal-close-{{ section.id }}"
    style="position:absolute;top:1.25rem;right:1.25rem;background:rgba(255,255,255,0.1);border:none;border-radius:50%;width:2.5rem;height:2.5rem;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#fff;"
    aria-label="Close"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>
  <div style="max-width:56rem;width:90vw;text-align:center;">
    <img id="cg-modal-img-{{ section.id }}" src="" alt="" style="max-height:75vh;width:auto;max-width:100%;border-radius:0.75rem;">
    <div style="margin-top:1rem;">
      <p id="cg-modal-caption-{{ section.id }}" style="color:#fff;font-weight:600;margin:0;"></p>
      <p id="cg-modal-author-{{ section.id }}" style="color:rgba(255,255,255,0.55);font-size:0.875rem;margin:0;"></p>
    </div>
  </div>
</div>

<script>
(function () {
  var sid     = '{{ section.id }}';
  var modal   = document.getElementById('cg-modal-' + sid);
  var img     = document.getElementById('cg-modal-img-' + sid);
  var caption = document.getElementById('cg-modal-caption-' + sid);
  var author  = document.getElementById('cg-modal-author-' + sid);
  var close   = document.getElementById('cg-modal-close-' + sid);

  document.querySelectorAll('#birdlabs-cg-' + sid + ' [data-cg-trigger]').forEach(function (el) {
    el.addEventListener('click', function () {
      if (!this.dataset.src) return;
      img.src           = this.dataset.src;
      img.alt           = this.dataset.caption || '';
      caption.textContent = this.dataset.caption || '';
      author.textContent  = this.dataset.author  || '';
      modal.style.display = 'flex';
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeModal() {
    modal.style.display = 'none';
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  close.addEventListener('click', closeModal);
  modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal(); });
}());
</script>

{% schema %}
{
  "name": "BirdLabs — Grower Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Header Text"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge label",
      "default": "COMMUNITY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Grower Gallery"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Real gardens from our community of Flora Bella growers"
    },
    {
      "type": "header",
      "content": "Header Alignment"
    },
    {
      "type": "select",
      "id": "header_h_align",
      "label": "Horizontal alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "header_v_align",
      "label": "Vertical alignment",
      "info": "Only applies when Header height is set above 0.",
      "options": [
        { "value": "top",    "label": "Top"    },
        { "value": "center", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "top"
    },
    {
      "type": "range",
      "id": "header_height",
      "label": "Header height (0 = auto)",
      "min": 0,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge text color",
      "default": "#7cb342"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#f0f7e6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#4b5563"
    },
    {
      "type": "header",
      "content": "Gallery Grid"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between images",
      "min": 4,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Join our WhatsApp Community"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "Button background",
      "default": "#7cb342"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Gallery image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Morning in the garden"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Grower name",
          "default": "Sarah M."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BirdLabs — Grower Gallery",
      "blocks": [
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" }
      ]
    }
  ]
}
{% endschema %}
