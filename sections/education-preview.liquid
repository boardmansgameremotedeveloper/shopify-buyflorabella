<section class="fb-education" style="background:{{ section.settings.background_color }};">
  <div class="fb-container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2 class="fb-section-title fb-heading" style="color:{{ section.settings.heading_color }};margin-bottom:0.75rem;">{{ section.settings.heading }}</h2>
      <p class="fb-section-subtitle" style="color:{{ section.settings.subheading_color }};">{{ section.settings.subheading }}</p>
    </div>

    <div class="fb-education__grid">
      {%- if section.settings.blog_handle != blank -%}
        {%- assign blog_source = blogs[section.settings.blog_handle] -%}
        {%- if blog_source != blank -%}
          {%- for article in blog_source.articles limit: 3 -%}
            <a href="{{ article.url }}" class="fb-edu-card">
              {%- if article.image != blank -%}
                <div style="overflow:hidden;height:12rem;">
                  {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: article.title, class: 'fb-edu-card__image' }}
                </div>
              {%- else -%}
                <div style="height:12rem;background:rgba(124,179,66,0.1);display:flex;align-items:center;justify-content:center;">
                  <span style="font-size:2.5rem;">🌿</span>
                </div>
              {%- endif -%}
              <div class="fb-edu-card__body">
                <p class="fb-edu-card__meta">{{ article.published_at | date: '%b %d, %Y' }} &middot; {{ article.author }}</p>
                <h3 class="fb-edu-card__title">{{ article.title }}</h3>
                {%- if article.excerpt != blank -%}
                  <p class="fb-edu-card__desc">{{ article.excerpt | strip_html | truncate: 120 }}</p>
                {%- endif -%}
              </div>
            </a>
          {%- endfor -%}
        {%- endif -%}
      {%- else -%}
        {%- comment -%} Fallback: show manual cards from blocks {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'article_card' -%}
            <a href="{{ block.settings.article_url }}" class="fb-edu-card" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <div style="overflow:hidden;height:12rem;">
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'fb-edu-card__image' }}
                </div>
              {%- endif -%}
              <div class="fb-edu-card__body">
                <p class="fb-edu-card__meta">{{ block.settings.meta }}</p>
                <h3 class="fb-edu-card__title">{{ block.settings.title }}</h3>
                <p class="fb-edu-card__desc">{{ block.settings.description }}</p>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div style="text-align:center;margin-top:3rem;">
        <a href="{{ section.settings.cta_url | default: '/blogs/news' }}" class="fb-btn-secondary" style="color:#111;">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Education Preview",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Learn To Treat Soil As A Living System"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-heading",
      "default": "Expert knowledge made accessible for gardeners at every level"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Sub-heading color",
      "default": "#9ca3af"
    },
    {
      "type": "text",
      "id": "blog_handle",
      "label": "Blog handle",
      "info": "Enter your Shopify blog handle (e.g. 'news' or 'learn'). Leave blank to use manual cards below.",
      "default": "news"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "View all articles"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA button URL"
    }
  ],
  "blocks": [
    {
      "type": "article_card",
      "name": "Manual article card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "meta",
          "label": "Meta (date / author)",
          "default": "7 min read"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "More Than NPK: Why Soil Systems Matter"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Traditional fertilizers focus on NPK. Flora Bella focuses on the soil system that makes NPK work better."
        },
        {
          "type": "url",
          "id": "article_url",
          "label": "Article URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Education Preview"
    }
  ]
}
{% endschema %}
