<section class="fb-gallery">
  <div class="fb-container">
    <div style="text-align:center;margin-bottom:3rem;">
      <div class="fb-badge" style="margin-bottom:1rem;">COMMUNITY</div>
      <h1 class="fb-section-title fb-heading" style="color:#111;margin-bottom:1rem;">{{ section.settings.heading }}</h1>
      <p class="fb-section-subtitle" style="color:#4b5563;">{{ section.settings.subheading }}</p>
    </div>

    <div class="fb-gallery__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'gallery_image' -%}
          <div
            class="fb-gallery__item"
            {{ block.shopify_attributes }}
            data-gallery-trigger
            data-caption="{{ block.settings.caption | escape }}"
            data-author="{{ block.settings.author | escape }}"
            {%- if block.settings.image != blank -%}
            data-src="{{ block.settings.image | image_url: width: 1200 }}"
            {%- endif -%}
          >
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.caption }}
            {%- else -%}
              <div style="width:100%;height:100%;background:rgba(124,179,66,0.1);display:flex;align-items:center;justify-content:center;"><span style="font-size:2rem;">🌿</span></div>
            {%- endif -%}
            <div class="fb-gallery__item-overlay">
              <p class="fb-gallery__item-caption">{{ block.settings.caption }}</p>
              <p class="fb-gallery__item-author">{{ block.settings.author }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <div style="text-align:center;margin-top:3rem;">
        {%- if section.settings.cta_url != blank -%}
          <a href="{{ section.settings.cta_url }}" class="fb-btn-primary" target="_blank" rel="noopener">{{ section.settings.cta_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{%- comment -%} Lightbox modal {%- endcomment -%}
<div id="fb-gallery-modal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.9);align-items:center;justify-content:center;" aria-hidden="true" role="dialog">
  <button id="fb-gallery-close" style="position:absolute;top:1.25rem;right:1.25rem;background:rgba(255,255,255,0.1);border:none;border-radius:50%;width:2.5rem;height:2.5rem;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#fff;" aria-label="Close">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
  <div style="max-width:56rem;width:90vw;text-align:center;">
    <img id="fb-gallery-modal-img" src="" alt="" style="max-height:75vh;width:auto;max-width:100%;border-radius:0.75rem;">
    <div style="margin-top:1rem;">
      <p id="fb-gallery-modal-caption" style="color:#fff;font-weight:600;margin:0;"></p>
      <p id="fb-gallery-modal-author" style="color:rgba(255,255,255,0.55);font-size:0.875rem;margin:0;"></p>
    </div>
  </div>
</div>

<script>
(function() {
  var modal = document.getElementById('fb-gallery-modal');
  var modalImg = document.getElementById('fb-gallery-modal-img');
  var modalCaption = document.getElementById('fb-gallery-modal-caption');
  var modalAuthor = document.getElementById('fb-gallery-modal-author');
  var closeBtn = document.getElementById('fb-gallery-close');

  document.querySelectorAll('[data-gallery-trigger]').forEach(function(item) {
    item.addEventListener('click', function() {
      var src = this.dataset.src;
      var caption = this.dataset.caption;
      var author = this.dataset.author;
      if (!src) return;
      modalImg.src = src;
      modalImg.alt = caption;
      modalCaption.textContent = caption;
      modalAuthor.textContent = author;
      modal.style.display = 'flex';
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeModal() {
    modal.style.display = 'none';
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  closeBtn.addEventListener('click', closeModal);
  modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
})();
</script>

{% schema %}
{
  "name": "Community Gallery",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Grower Gallery"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-heading",
      "default": "Real gardens from our community of Flora Bella growers"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Join our WhatsApp Community"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Gallery image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Morning in the garden"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author / Grower name",
          "default": "Sarah M."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Community Gallery"
    }
  ]
}
{% endschema %}
