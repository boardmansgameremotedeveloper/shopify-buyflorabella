<footer class="fb-footer" role="contentinfo">
  <div class="fb-container">
    <div class="fb-footer__grid">

      {%- comment -%} Column 1: Brand {%- endcomment -%}
      <div class="fb-footer__brand">
        {%- if section.settings.logo != blank -%}
          <a href="{{ routes.root_url }}">
            {{ section.settings.logo | image_url: width: 200 | image_tag: loading: 'lazy', alt: shop.name, style: 'height:3.5rem;width:auto;margin-bottom:1rem;display:block;' }}
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" style="color:#fff;font-weight:800;font-size:1.25rem;text-decoration:none;display:block;margin-bottom:1rem;font-family:var(--font-heading-family);">{{ shop.name }}</a>
        {%- endif -%}
        <p>{{ section.settings.brand_description }}</p>
        <div class="fb-footer__social">
          {%- if section.settings.social_instagram != blank -%}
            <a href="{{ section.settings.social_instagram }}" aria-label="Instagram" rel="noopener" target="_blank">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_facebook != blank -%}
            <a href="{{ section.settings.social_facebook }}" aria-label="Facebook" rel="noopener" target="_blank">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.social_youtube != blank -%}
            <a href="{{ section.settings.social_youtube }}" aria-label="YouTube" rel="noopener" target="_blank">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Column 2: Quick Links {%- endcomment -%}
      <div>
        <h4 class="fb-footer__heading">Quick Links</h4>
        <ul class="fb-footer__links">
          {%- for link in section.settings.footer_menu_1.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} Column 3: Help & Support {%- endcomment -%}
      <div>
        <h4 class="fb-footer__heading">Help &amp; Support</h4>
        <ul class="fb-footer__links">
          {%- for link in section.settings.footer_menu_2.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      </div>

      {%- comment -%} Column 4: Stay Connected / Newsletter {%- endcomment -%}
      <div>
        <h4 class="fb-footer__heading">Stay Connected</h4>
        <p style="color:rgba(255,255,255,0.55);font-size:0.875rem;margin-bottom:1rem;line-height:1.65;">
          {{ section.settings.newsletter_description }}
        </p>
        {%- if section.settings.omnisend_form_id != blank -%}
          <div id="{{ section.settings.omnisend_form_id }}"></div>
        {%- else -%}
          {%- form 'customer', id: 'footer-newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div style="display:flex;flex-direction:column;gap:0.625rem;">
              <input
                type="email"
                name="contact[email]"
                placeholder="Your email address"
                required
                style="width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.2);border-radius:0.75rem;padding:0.75rem 1rem;color:#fff;font-size:0.9rem;outline:none;"
              >
              <button type="submit" class="fb-btn-primary" style="width:100%;justify-content:center;">
                Get growing tips
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
            </div>
          {%- endform -%}
        {%- endif -%}
      </div>

    </div>

    <div class="fb-footer__bottom">
      <div class="fb-footer__bottom-row">
        <p style="margin:0;">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
        <p style="margin:0;">{{ section.settings.credits }}</p>
      </div>
      <div class="fb-footer__policy-links">
        {%- for link in shop.policies -%}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {%- endfor -%}
        <a href="{{ routes.root_url }}contact">Contact</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "class": "section-footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium bio trace minerals for healthier, more vibrant gardens. Trusted by organic growers for over 25 years."
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "Quick Links menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "Help & Support menu"
    },
    {
      "type": "textarea",
      "id": "newsletter_description",
      "label": "Newsletter description",
      "default": "Get growing tips and exclusive offers delivered to your inbox."
    },
    {
      "type": "text",
      "id": "omnisend_form_id",
      "label": "Omnisend embedded form ID",
      "info": "Enter the full element ID (e.g. omnisend-embedded-v2-...). Leave blank to show built-in email form."
    },
    {
      "type": "text",
      "id": "credits",
      "label": "Credits line",
      "default": "Site by BIRD Labs 🐦"
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
