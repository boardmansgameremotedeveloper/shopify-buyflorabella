  ],
  "blocks": [
    {
      "type": "video_reel",
      "name": "Video",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Video title",
          "default": "Video title"
        },
        {
          "type": "video_url",
          "id": "video_url",
