<section class="fb-community fb-gradient-offwhite" id="community">
  <div class="fb-container">
    <div style="text-align:center;margin-bottom:3rem;">
      <h2 class="fb-section-title fb-heading" style="color:#111;margin-bottom:1rem;">{{ section.settings.heading }}</h2>
      <p class="fb-section-subtitle" style="color:#4b5563;">{{ section.settings.subheading }}</p>
    </div>

    <div class="fb-community__grid">

      {%- comment -%} Email signup card {%- endcomment -%}
      <div class="fb-community__card">
        <div class="fb-community__icon-wrap">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#7cb342" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h3 style="font-size:1.375rem;font-weight:800;color:#111;margin:0 0 0.75rem;font-family:var(--font-heading-family);">{{ section.settings.email_title }}</h3>
        <p style="color:#6b7280;font-size:0.9375rem;line-height:1.65;margin-bottom:1.25rem;">{{ section.settings.email_description }}</p>

        {%- if section.settings.omnisend_form_id != blank -%}
          <div id="{{ section.settings.omnisend_form_id }}"></div>
        {%- else -%}
          {%- form 'customer', id: 'community-newsletter-{{ section.id }}' -%}
            <input type="hidden" name="contact[tags]" value="newsletter,community-signup">
            <div style="display:flex;flex-direction:column;gap:0.625rem;">
              <input
                type="email"
                name="contact[email]"
                placeholder="Your email address"
                required
                style="width:100%;background:#f9fafb;border:1px solid #e5e7eb;border-radius:0.75rem;padding:0.75rem 1rem;color:#111;font-size:0.9rem;outline:none;transition:border-color 0.2s;"
              >
              <button type="submit" class="fb-btn-primary" style="width:100%;justify-content:center;">
                {{ section.settings.email_button_label | default: 'Get soil tips' }}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
            </div>
          {%- endform -%}
        {%- endif -%}
      </div>

      {%- comment -%} Community / WhatsApp card {%- endcomment -%}
      <div class="fb-community__card">
        <div class="fb-community__icon-wrap">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#7cb342" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 style="font-size:1.375rem;font-weight:800;color:#111;margin:0 0 0.75rem;font-family:var(--font-heading-family);">{{ section.settings.community_title }}</h3>
        <p style="color:#6b7280;font-size:0.9375rem;line-height:1.65;margin-bottom:1.5rem;">{{ section.settings.community_description }}</p>

        {%- if section.settings.community_url != blank -%}
          <a href="{{ section.settings.community_url }}" class="fb-btn-primary" target="_blank" rel="noopener" style="display:inline-flex;">
            {{ section.settings.community_button_label | default: 'Join the community' }}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-left:0.5rem;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        {%- else -%}
          <a href="/community" class="fb-btn-secondary">
            {{ section.settings.community_button_label | default: 'View grower stories' }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Community Callout",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A Community For Growers Who Care About Soil Health"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sub-heading",
      "default": "Flora Bella exists to make expert level soil care simple for everyday gardeners. Join our growing community for seasonal tips, real case studies, and honest conversations about what works."
    },
    {
      "type": "header",
      "content": "Email card"
    },
    {
      "type": "text",
      "id": "email_title",
      "label": "Email card title",
      "default": "Join the email list"
    },
    {
      "type": "textarea",
      "id": "email_description",
      "label": "Email card description",
      "default": "Enter your email to receive practical soil tips and early access to new batches."
    },
    {
      "type": "text",
      "id": "email_button_label",
      "label": "Email button label",
      "default": "Get soil tips"
    },
    {
      "type": "text",
      "id": "omnisend_form_id",
      "label": "Omnisend form element ID",
      "info": "Leave blank to show built-in Shopify email form."
    },
    {
      "type": "header",
      "content": "Community card"
    },
    {
      "type": "text",
      "id": "community_title",
      "label": "Community card title",
      "default": "Join our Grower Community"
    },
    {
      "type": "textarea",
      "id": "community_description",
      "label": "Community card description",
      "default": "Connect with other gardeners, share your results, and get tips from Flora Bella growers around the country."
    },
    {
      "type": "url",
      "id": "community_url",
      "label": "Community link (WhatsApp, Discord, etc.)"
    },
    {
      "type": "text",
      "id": "community_button_label",
      "label": "Community button label",
      "default": "Join the community"
    }
  ],
  "presets": [
    {
      "name": "Community Callout"
    }
  ]
}
{% endschema %}
