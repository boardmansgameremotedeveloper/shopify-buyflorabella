{%- liquid
  if section.blocks.size > 0
    assign announcement_bar = true
  endif
-%}

{%- if announcement_bar -%}
<div class="fb-announcement-bar" role="region" aria-label="Announcement">
  <div class="fb-container">
    {%- if section.blocks.size == 1 -%}
      {%- assign block = section.blocks.first -%}
      {%- if block.settings.text != blank -%}
        <p>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" style="color:#fff;text-decoration:underline;">
          {%- endif -%}
          {{ block.settings.text | escape }}
          {%- if block.settings.coupon != blank -%}
            &nbsp;<span class="fb-coupon">{{ block.settings.coupon | escape }}</span>
          {%- endif -%}
          {%- if block.settings.link != blank -%}
            </a>
          {%- endif -%}
        </p>
      {%- endif -%}
    {%- elsif section.blocks.size > 1 -%}
      <div class="fb-announcement-bar__rotating" id="fb-ann-{{ section.id }}">
        {%- for block in section.blocks -%}
          <p class="fb-announcement-bar__slide{% if forloop.first %} active{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}
              <a href="{{ block.settings.link }}" style="color:#fff;text-decoration:underline;">
            {%- endif -%}
            {{ block.settings.text | escape }}
            {%- if block.settings.coupon != blank -%}
              &nbsp;<span class="fb-coupon">{{ block.settings.coupon | escape }}</span>
            {%- endif -%}
            {%- if block.settings.link != blank -%}
              </a>
            {%- endif -%}
          </p>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% if section.blocks.size > 1 %}
<style>
  .fb-announcement-bar__rotating .fb-announcement-bar__slide { display: none; }
  .fb-announcement-bar__rotating .fb-announcement-bar__slide.active { display: block; }
</style>
<script>
(function() {
  var container = document.getElementById('fb-ann-{{ section.id }}');
  if (!container) return;
  var slides = container.querySelectorAll('.fb-announcement-bar__slide');
  var current = 0;
  var speed = {{ section.settings.change_slides_speed | default: 5 }} * 1000;
  setInterval(function() {
    slides[current].classList.remove('active');
    current = (current + 1) % slides.length;
    slides[current].classList.add('active');
  }, speed);
})();
</script>
{% endif %}
{%- endif -%}

{% schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 12,
  "class": "announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Rotation speed (multiple messages)",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Free shipping on orders over $50",
          "label": "Message"
        },
        {
          "type": "text",
          "id": "coupon",
          "label": "Coupon code (optional)",
          "info": "Displays highlighted after the message"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Free shipping on orders over $50 — Use code:"
          }
        }
      ]
    }
  ]
}
{% endschema %}
