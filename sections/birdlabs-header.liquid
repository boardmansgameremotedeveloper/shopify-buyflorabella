{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-notification.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign cart_count = cart.item_count
-%}

<header class="fb-header" id="fb-header" role="banner">
  <div class="fb-header__inner">

    <div class="fb-header__left">
      <button
        class="fb-header__icon-btn"
        id="fb-mobile-menu-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="fb-mobile-menu"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#7cb342" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>

      <button
        class="fb-header__icon-btn"
        id="fb-search-toggle"
        aria-label="Toggle search"
        aria-expanded="false"
        aria-controls="fb-search-bar"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7cb342" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </div>

    <div class="fb-header__logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 300 | image_tag: loading: 'eager', alt: shop.name, class: 'fb-header__logo-img' }}
        {%- else -%}
          <span style="color:#fff;font-weight:800;font-size:1.25rem;letter-spacing:-0.02em;font-family:var(--font-heading-family);">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <div class="fb-header__right">
      <nav class="fb-header__nav" aria-label="Main navigation">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="fb-header__nav-link">{{ link.title }}</a>
        {%- endfor -%}
      </nav>

      <a href="{{ routes.account_url }}" class="fb-header__icon-btn" aria-label="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>

      <a href="{{ routes.cart_url }}" class="fb-header__icon-btn" aria-label="Cart ({{ cart_count }} items)" style="position:relative;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        {%- if cart_count > 0 -%}
          <span class="fb-header__cart-count" aria-hidden="true">{{ cart_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>

  <div class="fb-header__search-bar" id="fb-search-bar" hidden>
    <div class="fb-container">
      <form action="{{ routes.search_url }}" method="get" role="search">
        <input type="search" name="q" placeholder="Search products, articles..." aria-label="Search" autocomplete="off">
        <input type="hidden" name="type" value="product,article">
      </form>
    </div>
  </div>
</header>

<div class="fb-mobile-menu" id="fb-mobile-menu" aria-hidden="true" role="dialog" aria-label="Navigation">
  <div class="fb-mobile-menu__overlay" id="fb-mobile-overlay"></div>
  <div class="fb-mobile-menu__panel">
    <div class="fb-mobile-menu__header">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 200 | image_tag: loading: 'eager', alt: shop.name, style: 'height:4rem;width:auto;' }}
      {%- else -%}
        <span style="color:#fff;font-weight:800;font-size:1.125rem;">{{ shop.name }}</span>
      {%- endif -%}
      <button class="fb-mobile-menu__close" id="fb-mobile-close" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <nav class="fb-mobile-menu__nav" aria-label="Mobile navigation">
      {%- for link in section.settings.menu.links -%}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {%- endfor -%}
      <a href="{{ routes.account_url }}">Account</a>
      <a href="{{ routes.cart_url }}">Cart ({{ cart_count }})</a>
    </nav>
  </div>
</div>

<style>
  .fb-header__nav-link {
    color: rgba(255,255,255,0.9);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.3s ease, transform 0.3s ease;
    display: inline-block;
  }
  .fb-header__nav-link:hover {
    color: #7cb342;
    transform: translateY(-2px) scale(1.06);
    text-decoration: none;
  }
  .fb-header__logo-img {
    height: 5rem;
    width: auto;
    transition: height 0.3s ease;
  }
  .fb-header--scrolled .fb-header__logo-img {
    height: 3.5rem;
  }
</style>

<script>
(function() {
  var header = document.getElementById('fb-header');
  var mobileMenu = document.getElementById('fb-mobile-menu');
  var mobileToggle = document.getElementById('fb-mobile-menu-toggle');
  var mobileClose = document.getElementById('fb-mobile-close');
  var overlay = document.getElementById('fb-mobile-overlay');
  var searchToggle = document.getElementById('fb-search-toggle');
  var searchBar = document.getElementById('fb-search-bar');

  window.addEventListener('scroll', function() {
    header.classList.toggle('fb-header--scrolled', window.scrollY > 80);
  }, { passive: true });

  function openMenu() {
    mobileMenu.classList.add('fb-mobile-menu--open');
    mobileMenu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    mobileMenu.classList.remove('fb-mobile-menu--open');
    mobileMenu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  mobileToggle.addEventListener('click', openMenu);
  mobileClose.addEventListener('click', closeMenu);
  overlay.addEventListener('click', closeMenu);

  searchToggle.addEventListener('click', function() {
    if (searchBar.hasAttribute('hidden')) {
      searchBar.removeAttribute('hidden');
      searchToggle.setAttribute('aria-expanded', 'true');
      searchBar.querySelector('input').focus();
    } else {
      searchBar.setAttribute('hidden', '');
      searchToggle.setAttribute('aria-expanded', 'false');
    }
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeMenu(); searchBar.setAttribute('hidden', ''); }
  });
})();
</script>

{% schema %}
{
  "name": "BirdLabs — Header",
  "class": "section-header",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Navigation menu"
    }
  ],
  "presets": [
    {
      "name": "BirdLabs — Header"
    }
  ]
}
{% endschema %}
