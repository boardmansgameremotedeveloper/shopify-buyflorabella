<section class="birdlabs-mc" id="birdlabs-mc-{{ section.id }}">

  {%- if section.settings.bg_image != blank -%}
    <div class="birdlabs-mc__bg-image">
      {{ section.settings.bg_image | image_url: width: 2400 | image_tag: loading: 'lazy', alt: '', class: 'birdlabs-mc__bg-img' }}
    </div>
    <div class="birdlabs-mc__bg-overlay"></div>
  {%- endif -%}

  <div class="fb-container birdlabs-mc__inner">

    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="birdlabs-mc__header">
        {%- if section.settings.heading != blank -%}
          <h2 class="birdlabs-mc__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="birdlabs-mc__description">{{ section.settings.description | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="birdlabs-mc__grid" id="birdlabs-mc-grid-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="birdlabs-mc__card" {{ block.shopify_attributes }}>

            {%- if block.settings.image != blank -%}
              <div class="birdlabs-mc__image-wrap">
                {{ block.settings.image | image_url: width: 800 | image_tag:
                    loading: 'lazy',
                    alt: block.settings.heading,
                    class: 'birdlabs-mc__card-img'
                }}
                {%- if block.settings.icon != blank -%}
                  <div class="birdlabs-mc__icon-badge"
                    {%- if block.settings.icon_bg_color != blank -%}
                      style="background-color: {{ block.settings.icon_bg_color }};"
                    {%- endif -%}
                  >
                    {{ block.settings.icon | image_url: width: 80 | image_tag:
                        loading: 'lazy',
                        alt: '',
                        class: 'birdlabs-mc__icon-img'
                    }}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            <div class="birdlabs-mc__card-body">
              {%- if block.settings.heading != blank -%}
                <h3 class="birdlabs-mc__card-heading">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="birdlabs-mc__card-desc">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
/* ── Outer section ──────────────────────────────────────── */
#birdlabs-mc-{{ section.id }} {
  position: relative;
  overflow: hidden;
  background-color: {{ section.settings.bg_color }};
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

/* ── Background image ───────────────────────────────────── */
.birdlabs-mc__bg-image {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.birdlabs-mc__bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}
.birdlabs-mc__bg-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background-color: {{ section.settings.bg_overlay_color }};
  opacity: {{ section.settings.bg_overlay_opacity | divided_by: 100.0 }};
}

/* ── Inner content above bg ─────────────────────────────── */
.birdlabs-mc__inner {
  position: relative;
  z-index: 2;
}

/* ── Section header ─────────────────────────────────────── */
.birdlabs-mc__header {
  text-align: center;
  margin-bottom: 2.5rem;
}
.birdlabs-mc__heading {
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  font-weight: 800;
  color: {{ section.settings.heading_color }};
  font-family: var(--font-heading-family, Georgia, serif);
  margin: 0 0 0.75rem;
  line-height: 1.15;
}
.birdlabs-mc__description {
  font-size: 1rem;
  color: {{ section.settings.description_color }};
  max-width: 48rem;
  margin: 0 auto;
  line-height: 1.65;
}

/* ── Grid ───────────────────────────────────────────────── */
#birdlabs-mc-grid-{{ section.id }} {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
  gap: {{ section.settings.column_gap }}px;
}
@media (min-width: 768px) {
  #birdlabs-mc-grid-{{ section.id }} {
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  }
}

/* ── Card ───────────────────────────────────────────────── */
.birdlabs-mc__card {
  background: {{ section.settings.card_bg_color }};
  border-radius: {{ section.settings.card_radius }}px;
  overflow: hidden;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.birdlabs-mc__card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.12);
}

/* ── Card image + icon overlay ──────────────────────────── */
.birdlabs-mc__image-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: {{ section.settings.image_ratio }};
  overflow: hidden;
}
.birdlabs-mc__card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.4s ease;
}
.birdlabs-mc__card:hover .birdlabs-mc__card-img {
  transform: scale(1.05);
}

/* icon badge sits in bottom-left corner of the image */
.birdlabs-mc__icon-badge {
  position: absolute;
  bottom: 0.75rem;
  left: 0.75rem;
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 0.5rem;
  background: rgba(255,255,255,0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  overflow: hidden;
}
.birdlabs-mc__icon-img {
  width: 1.5rem;
  height: 1.5rem;
  object-fit: contain;
  display: block;
}

/* ── Card body ──────────────────────────────────────────── */
.birdlabs-mc__card-body {
  padding: 1rem 1.125rem 1.25rem;
}
.birdlabs-mc__card-heading {
  font-size: 1rem;
  font-weight: 700;
  color: {{ section.settings.card_heading_color }};
  margin: 0 0 0.375rem;
  font-family: var(--font-heading-family, Georgia, serif);
  line-height: 1.3;
}
.birdlabs-mc__card-desc {
  font-size: 0.875rem;
  color: {{ section.settings.card_desc_color }};
  margin: 0;
  line-height: 1.6;
}
</style>

{% schema %}
{
  "name": "BirdLabs — Feature Grid",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Features"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Everything you need, all in one place."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#4b5563"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image (optional)"
    },
    {
      "type": "color",
      "id": "bg_overlay_color",
      "label": "Overlay color",
      "default": "#000000",
      "info": "Applied over the background image."
    },
    {
      "type": "range",
      "id": "bg_overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 0
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Card corner radius",
      "default": 12
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1 / 1", "label": "Square" },
        { "value": "4 / 3", "label": "Landscape" },
        { "value": "3 / 4", "label": "Portrait" },
        { "value": "16 / 9", "label": "Widescreen" }
      ],
      "default": "4 / 3"
    },
    {
      "type": "color",
      "id": "card_heading_color",
      "label": "Card heading color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "card_desc_color",
      "label": "Card description color",
      "default": "#6b7280"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "range",
      "id": "column_gap",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 20
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Feature card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Featured image"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (overlaid on image)"
        },
        {
          "type": "color",
          "id": "icon_bg_color",
          "label": "Icon badge color",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Describe this feature in a few words."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BirdLabs — Feature Grid",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "heading": "Feature One",
            "description": "Describe this feature in a few words."
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Feature Two",
            "description": "Describe this feature in a few words."
          }
        },
        {
          "type": "column",
          "settings": {
            "heading": "Feature Three",
            "description": "Describe this feature in a few words."
          }
        }
      ]
    }
  ]
}
{% endschema %}
